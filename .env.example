# PostgreSQL (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/muvekkil_kasa_saas?schema=public"

# API
PORT=4000
NODE_ENV=development

# JWT (örnek: güçlü rastgele secret kullanın; en az 16 karakter)
JWT_SECRET="change-me-to-a-long-random-string-at-least-16"
JWT_EXPIRES_IN="8h"

# CORS: Vite dev sunucusu
CORS_ORIGIN="http://localhost:5173"

# Woontegra süper admin JWT (tanımlı değilse JWT_SECRET kullanılır; admin token payload `typ: admin`)
# ADMIN_JWT_SECRET="ayri-guclu-secret-min-16"
# ADMIN_JWT_EXPIRES_IN="8h"

# İlk süper admin: npm run seed:admin
# ADMIN_SEED_USERNAME=admin
# ADMIN_SEED_EMAIL=admin@woontegra.com
# ADMIN_SEED_PASSWORD="GüçlüBirŞifre"
# ADMIN_SEED_AD_SOYAD="Woontegra Yönetici"
# ADMIN_SEED_ROLE=SUPER_ADMIN
