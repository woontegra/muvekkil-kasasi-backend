# PostgreSQL (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/muvekkil_kasa_saas?schema=public"

# API
PORT=4000
NODE_ENV=development

# JWT (örnek: güçlü rastgele secret kullanın; en az 16 karakter)
JWT_SECRET="change-me-to-a-long-random-string-at-least-16"
JWT_EXPIRES_IN="8h"

# CORS: Vite dev sunucusu
CORS_ORIGIN="http://localhost:5173"

# Şifre sıfırlama e-postasındaki frontend link kökü (öncelik: RESET_PASSWORD_URL > FRONTEND_URL > PUBLIC_APP_URL > CORS_ORIGIN)
# FRONTEND_URL="http://localhost:5173"
# PUBLIC_APP_URL="http://localhost:5173"

# Gmail SMTP kolay kurulum (SMTP_* tanımlı değilse kullanılır)
# GMAIL_USER=info@woontegra.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# MAIL_FROM="Müvekkil Kasa Defteri <info@woontegra.com>"
# FRONTEND_URL=http://localhost:5173

# Genel SMTP (SMTP_HOST + SMTP_USER + SMTP_PASS tanımlıysa Gmail'den önce kullanılır)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="noreply@example.com"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="Müvekkil Kasa <noreply@example.com>"
# MAIL_FROM="noreply@example.com"
# SMTP_SECURE=false

# Woontegra süper admin JWT (tanımlı değilse JWT_SECRET kullanılır; admin token payload `typ: admin`)
# ADMIN_JWT_SECRET="ayri-guclu-secret-min-16"
# ADMIN_JWT_EXPIRES_IN="8h"

# İlk süper admin: npm run seed:admin
# ADMIN_SEED_USERNAME=admin
# ADMIN_SEED_EMAIL=admin@woontegra.com
# ADMIN_SEED_PASSWORD="GüçlüBirŞifre"
# ADMIN_SEED_AD_SOYAD="Woontegra Yönetici"
# ADMIN_SEED_ROLE=SUPER_ADMIN

# Woontegra Website ödeme sonrası Müvekkil Kasa SaaS tenant/büro oluşturma entegrasyonu (server-to-server secret)
# WOONTEGRA_WEBSITE_PROVISION_SECRET=""

# ACTIVATION_TOKEN_EXPIRES_HOURS=72
