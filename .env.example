# PostgreSQL (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/muvekkil_kasa_saas?schema=public"

# API
PORT=4000
NODE_ENV=development

# JWT (örnek: güçlü rastgele secret kullanın; en az 16 karakter)
JWT_SECRET="change-me-to-a-long-random-string-at-least-16"
JWT_EXPIRES_IN="8h"

# CORS: Vite dev sunucusu
CORS_ORIGIN="http://localhost:5173"

# Şifre sıfırlama e-postasındaki link kökü (yoksa CORS_ORIGIN kullanılır)
# PUBLIC_APP_URL="http://localhost:5173"
