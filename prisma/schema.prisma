generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Yıllık lisans / demo durumu (paket sistemi yok).
enum TenantLicenseStatus {
  DEMO
  AKTIF
  SURESI_DOLDU
  PASIF
}

/// Hukuk bürosu / kiracı
model Tenant {
  id           String   @id @default(uuid())
  buroAdi      String   @map("buro_adi")
  slug         String   @unique
  telefon      String?  @map("telefon")
  eposta       String?  @map("eposta")
  adres        String?  @map("adres")
  vergiNo      String?  @map("vergi_no")
  vergiDairesi String?  @map("vergi_dairesi")
  aktifMi      Boolean  @default(true) @map("aktif_mi")

  lisansBaslangicTarihi DateTime?             @map("lisans_baslangic")
  lisansBitisTarihi     DateTime?             @map("lisans_bitis")
  lisansDurumu          TenantLicenseStatus   @default(AKTIF) @map("lisans_durumu")
  demoMu                Boolean               @default(false) @map("demo_mu")
  demoBitisTarihi       DateTime?             @map("demo_bitis")
  sonOdemeTarihi        DateTime?             @map("son_odeme")
  yillikUcret           Decimal?              @map("yillik_ucret") @db.Decimal(14, 2)
  lisansNotlari         String?               @map("lisans_notlari")
  /// SaaS lisans anahtarı (kiracı başına; Woontegra Website veya süper admin oluşturma).
  lisansAnahtari        String?               @unique @map("lisans_anahtari")

  /// Woontegra Website ödeme sonrası teslimat idempotency: website sipariş kimliği (unique).
  externalOrderId    String? @unique @map("external_order_id")
  /// Woontegra Website ödeme sonrası teslimat: website müşteri kimliği.
  externalCustomerId String? @map("external_customer_id")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users        User[]
  auditLogs    AuditLog[]
  muvekkiller  Muvekkil[]
  dosyalar          Dosya[]
  kasaHareketleri       KasaHareketi[]
  vekaletUcretleri      VekaletUcreti[]
  vekaletTaksitleri     VekaletTaksiti[]
  vekaletTaksitOdemeleri VekaletTaksitOdeme[]
  ofisKasaHareketleri   OfisKasaHareketi[]
  importBatches         ImportBatch[]
  primKurallari         PrimKurali[]
  primKuralKademeleri   PrimKuralKademesi[]
  primDonemOdemeleri    PrimDonemOdemesi[]
  primPersoneller       PrimPersonel[]
  icraTahsilatAlacaklari IcraTahsilatAlacagi[]
  icraTahsilatTaksitleri IcraTahsilatTaksit[]
  icraTahsilatOdemeleri  IcraTahsilatOdeme[]
  licenseRenewals        TenantLicenseRenewal[]

  @@map("tenant")
}

enum LicenseRenewalSource {
  WOONTEGRA_WEBSITE
  SUPER_ADMIN
}

/// Lisans / üyelik yenileme geçmişi (Website renew veya Super Admin uzatma).
model TenantLicenseRenewal {
  id                 String               @id @default(uuid())
  tenantId           String               @map("tenant_id")
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  externalOrderId    String?              @unique @map("external_order_id")
  externalCustomerId String?              @map("external_customer_id")
  licenseKey         String?              @map("license_key")
  previousEndDate    DateTime             @map("previous_end_date")
  newEndDate         DateTime             @map("new_end_date")
  renewalDays        Int                  @map("renewal_days")
  amount             Decimal?             @db.Decimal(14, 2)
  currency           String               @default("TRY")
  paidAt             DateTime?            @map("paid_at")
  source             LicenseRenewalSource @map("source")
  note               String?
  createdAt          DateTime             @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("tenant_license_renewal")
}

enum UserRole {
  BURO_SAHIBI
  AVUKAT_YONETICI
  KATIP_PERSONEL
}

model User {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adSoyad          String    @map("ad_soyad")
  kullaniciAdi     String    @map("kullanici_adi")
  eposta           String?   @map("eposta")
  telefon          String?   @map("telefon")
  sifreHash        String    @map("sifre_hash")
  role             UserRole
  aktifMi          Boolean   @default(true) @map("aktif_mi")
  sonGirisTarihi   DateTime? @map("son_giris_tarihi")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  auditLogs             AuditLog[]
  passwordResetTokens   PasswordResetToken[]
  muvekkillerCreated    Muvekkil[]            @relation("MuvekkilCreatedBy")
  muvekkillerUpdated    Muvekkil[]            @relation("MuvekkilUpdatedBy")
  dosyalarCreated       Dosya[]               @relation("DosyaCreatedBy")
  dosyalarUpdated       Dosya[]               @relation("DosyaUpdatedBy")
  kasaHareketleriCreated KasaHareketi[]        @relation("KasaCreatedBy")
  kasaHareketleriUpdated KasaHareketi[]        @relation("KasaUpdatedBy")
  kasaHareketleriOnaylayan KasaHareketi[]     @relation("KasaOnaylayan")
  vekaletUcretleriCreated   VekaletUcreti[]   @relation("VekaletUcretiCreatedBy")
  vekaletUcretleriUpdated   VekaletUcreti[]   @relation("VekaletUcretiUpdatedBy")
  vekaletTaksitleriCreated   VekaletTaksiti[] @relation("VekaletTaksitCreatedBy")
  vekaletTaksitleriUpdated   VekaletTaksiti[] @relation("VekaletTaksitUpdatedBy")
  vekaletTaksitOdemeleriCreated VekaletTaksitOdeme[] @relation("VekaletTaksitOdemeCreatedBy")
  ofisKasaHareketleriCreated OfisKasaHareketi[] @relation("OfisKasaCreatedBy")
  ofisKasaHareketleriUpdated OfisKasaHareketi[] @relation("OfisKasaUpdatedBy")
  ofisKasaHareketleriOnaylayan OfisKasaHareketi[] @relation("OfisKasaOnaylayan")
  importBatchesCommitted       ImportBatch[]
  tahsilatlariYapanKasa        KasaHareketi[]        @relation("KasaTahsilatiYapan")
  tahsilatlariYapanVekalet     VekaletTaksitOdeme[]  @relation("VekaletOdemeTahsilatiYapan")
  tahsilatlariYapanOfisKasa    OfisKasaHareketi[]    @relation("OfisKasaTahsilatiYapan")
  primKurallari                PrimKurali[]
  primDonemOdemeleri           PrimDonemOdemesi[]
  primDonemOdemeleriIsaretleyen PrimDonemOdemesi[]   @relation("PrimDonemOdendiIsaretleyen")
  bagliPrimPersonel             PrimPersonel?         @relation("PrimPersonelBagliUser")
  icraTahsilatAlacaklariCreated IcraTahsilatAlacagi[] @relation("IcraAlacakCreatedBy")
  icraTahsilatAlacaklariUpdated IcraTahsilatAlacagi[] @relation("IcraAlacakUpdatedBy")
  icraTahsilatOdemeleriCreated  IcraTahsilatOdeme[]   @relation("IcraOdemeCreatedBy")
  tahsilatlariYapanIcraTahsilat IcraTahsilatOdeme[]   @relation("IcraOdemeTahsilatiYapan")

  @@unique([kullaniciAdi])
  @@unique([tenantId, eposta])
  @@index([tenantId])
  @@index([eposta])
  @@map("user")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?  @map("tenant_id")
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  meta       Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("audit_log")
}

enum MuvekkilTur {
  GERCEK
  TUZEL
}

model Muvekkil {
  id                String      @id @default(uuid())
  tenantId          String      @map("tenant_id")
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tur               MuvekkilTur
  gorunenAd         String      @map("gorunen_ad")
  adSoyad           String      @default("") @map("ad_soyad")
  sirketUnvani      String?     @map("sirket_unvani")
  telefon           String?
  eposta            String?
  notMetni          String?     @map("not_metni")
  yetkiliAdSoyad    String      @default("") @map("yetkili_ad_soyad")
  yetkiliTelefon    String      @default("") @map("yetkili_telefon")
  mudurAdSoyad      String      @default("") @map("mudur_ad_soyad")
  mudurTelefon      String      @default("") @map("mudur_telefon")
  muhasebeAdSoyad   String      @default("") @map("muhasebe_ad_soyad")
  muhasebeTelefon   String      @default("") @map("muhasebe_telefon")
  aktifMi           Boolean     @default(true) @map("aktif_mi")
  createdById       String      @map("created_by_id")
  createdBy         User        @relation("MuvekkilCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById       String?     @map("updated_by_id")
  updatedBy         User?       @relation("MuvekkilUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  dosyalar           Dosya[]
  kasaHareketleri    KasaHareketi[]
  vekaletUcretleri   VekaletUcreti[]
  vekaletTaksitleri  VekaletTaksiti[]
  vekaletTaksitOdemeleri VekaletTaksitOdeme[]
  icraTahsilatAlacaklari IcraTahsilatAlacagi[]

  @@index([tenantId, aktifMi])
  @@index([tenantId, gorunenAd])
  @@map("muvekkil")
}

enum DosyaDurumu {
  AKTIF
  PASIF
  KAPANDI
  ARSIV
}

enum DosyaTuru {
  DAVA
  ICRA
  DANISMANLIK
  DIGER
}

model Dosya {
  id           String       @id @default(uuid())
  tenantId     String       @map("tenant_id")
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  muvekkilId   String       @map("muvekkil_id")
  muvekkil     Muvekkil     @relation(fields: [muvekkilId], references: [id], onDelete: Cascade)
  konuBasligi  String       @map("konu_basligi")
  mahkeme      String?
  icraDairesi  String?      @map("icra_dairesi")
  dosyaNo      String?      @map("dosya_no")
  dosyaTuru    DosyaTuru    @map("dosya_turu")
  durum        DosyaDurumu
  aciklama     String?
  aktifMi      Boolean      @default(true) @map("aktif_mi")
  createdById  String       @map("created_by_id")
  createdBy    User         @relation("DosyaCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById  String?      @map("updated_by_id")
  updatedBy    User?        @relation("DosyaUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  kasaHareketleri   KasaHareketi[]
  vekaletUcreti     VekaletUcreti?
  vekaletTaksitleri VekaletTaksiti[]
  vekaletTaksitOdemeleri VekaletTaksitOdeme[]
  icraTahsilatAlacaklari IcraTahsilatAlacagi[]

  @@index([tenantId, muvekkilId, aktifMi])
  @@index([tenantId, aktifMi])
  @@map("dosya")
}

enum KasaHareketTipi {
  AVANS_GIRISI
  MASRAF
  DUZELTME
  VEKALET_TAHSILAT
}

enum KasaOnayDurumu {
  ONAYSIZ
  ONAYLI
  REDDEDILDI
}

enum OdemeYontemi {
  NAKIT
  BANKA
  KREDI_KARTI
  DIGER
}

/// Dosya / müvekkil kasasından bağımsız büro ofis kasası
enum OfisKasaIslemTipi {
  GELIR
  GIDER
  DUZELTME
}

enum OfisKasaOnayDurumu {
  ONAYSIZ
  ONAYLI
  REDDEDILDI
}

enum OfisKasaOdemeYontemi {
  NAKIT
  BANKA
  KREDI_KARTI
  DIGER
}

model OfisKasaHareketi {
  id                  String               @id @default(uuid())
  tenantId            String               @map("tenant_id")
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  islemTipi           OfisKasaIslemTipi    @map("islem_tipi")
  tarih               DateTime
  kategori            String               @map("kategori")
  ozelKategoriAdi     String?              @map("ozel_kategori_adi")
  aciklama            String?
  tutar               Decimal              @db.Decimal(14, 2)
  odemeYontemi        OfisKasaOdemeYontemi @map("odeme_yontemi")
  belgeNo             String               @map("belge_no")
  onayDurumu          OfisKasaOnayDurumu   @default(ONAYSIZ) @map("onay_durumu")
  onaylayanId         String?              @map("onaylayan_id")
  onaylayan           User?                @relation("OfisKasaOnaylayan", fields: [onaylayanId], references: [id], onDelete: SetNull)
  onayTarihi          DateTime?            @map("onay_tarihi")
  redSebebi           String?              @map("red_sebebi")
  orijinalHareketId   String?              @map("orijinal_hareket_id")
  orijinalHareket     OfisKasaHareketi?    @relation("OfisKasaDuzeltme", fields: [orijinalHareketId], references: [id], onDelete: SetNull)
  duzeltmeler         OfisKasaHareketi[]   @relation("OfisKasaDuzeltme")
  otomatikOnayMi      Boolean              @default(false) @map("otomatik_onay_mi")
  createdById         String               @map("created_by_id")
  createdBy           User                 @relation("OfisKasaCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  tahsilatiYapanUserId String?             @map("tahsilati_yapan_user_id")
  tahsilatiYapanUser  User?                @relation("OfisKasaTahsilatiYapan", fields: [tahsilatiYapanUserId], references: [id], onDelete: SetNull)
  tahsilatiYapanPersonelId String?         @map("tahsilati_yapan_personel_id")
  tahsilatiYapanPersonel PrimPersonel?     @relation("OfisKasaTahsilatiYapanPersonel", fields: [tahsilatiYapanPersonelId], references: [id], onDelete: SetNull)
  updatedById         String?              @map("updated_by_id")
  updatedBy           User?                @relation("OfisKasaUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  kaynakTipi          String?              @map("kaynak_tipi")
  kaynakId            String?              @map("kaynak_id")
  icraTahsilatOdeme   IcraTahsilatOdeme?
  vekaletTaksitOdeme  VekaletTaksitOdeme?

  @@unique([tenantId, belgeNo])
  @@unique([tenantId, kaynakTipi, kaynakId])
  @@index([tenantId, tarih])
  @@index([tenantId, onayDurumu])
  @@index([tenantId, islemTipi])
  @@index([tenantId, tahsilatiYapanUserId, tarih])
  @@index([tenantId, tahsilatiYapanPersonelId, tarih])
  @@map("ofis_kasa_hareketi")
}

model KasaHareketi {
  id                 String           @id @default(uuid())
  tenantId           String           @map("tenant_id")
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dosyaId            String           @map("dosya_id")
  dosya              Dosya            @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  muvekkilId         String           @map("muvekkil_id")
  muvekkil           Muvekkil         @relation(fields: [muvekkilId], references: [id], onDelete: Restrict)
  tip                KasaHareketTipi
  tarih              DateTime
  masrafTuru         String?          @map("masraf_turu")
  ozelMasrafAdi      String?          @map("ozel_masraf_adi")
  aciklama           String?
  tutar              Decimal          @db.Decimal(14, 2)
  /** Dosya kasası akışında kullanılmıyor; kolon geriye dönük uyumluluk için nullable. */
  odemeYontemi       OdemeYontemi?    @map("odeme_yontemi")
  masrafiYapanKisi   String?          @map("masrafi_yapan_kisi")
  belgeNo            String           @map("belge_no")
  onayDurumu         KasaOnayDurumu   @default(ONAYSIZ) @map("onay_durumu")
  onaylayanId        String?          @map("onaylayan_id")
  onaylayan          User?            @relation("KasaOnaylayan", fields: [onaylayanId], references: [id], onDelete: SetNull)
  onayTarihi         DateTime?        @map("onay_tarihi")
  redSebebi          String?          @map("red_sebebi")
  orijinalHareketId String?          @map("orijinal_hareket_id")
  orijinalHareket    KasaHareketi?    @relation("DuzeltmeBaglanti", fields: [orijinalHareketId], references: [id], onDelete: SetNull)
  duzeltmeler        KasaHareketi[]   @relation("DuzeltmeBaglanti")
  otomatikOnayMi     Boolean          @default(false) @map("otomatik_onay_mi")
  createdById        String           @map("created_by_id")
  createdBy          User             @relation("KasaCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  tahsilatiYapanUserId String?        @map("tahsilati_yapan_user_id")
  tahsilatiYapanUser User?            @relation("KasaTahsilatiYapan", fields: [tahsilatiYapanUserId], references: [id], onDelete: SetNull)
  tahsilatiYapanPersonelId String?    @map("tahsilati_yapan_personel_id")
  tahsilatiYapanPersonel PrimPersonel? @relation("KasaTahsilatiYapanPersonel", fields: [tahsilatiYapanPersonelId], references: [id], onDelete: SetNull)
  updatedById        String?          @map("updated_by_id")
  updatedBy          User?            @relation("KasaUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  vekaletTaksitOdeme VekaletTaksitOdeme?

  @@unique([tenantId, belgeNo])
  @@index([tenantId, dosyaId, tarih])
  @@index([tenantId, dosyaId, onayDurumu])
  @@index([tenantId, tahsilatiYapanUserId, tarih])
  @@index([tenantId, tahsilatiYapanPersonelId, tarih])
  @@map("kasa_hareketi")
}

enum VekaletTaksitOdemeDurumu {
  ODENMEDI
  KISMI_ODENDI
  ODENDI
  IPTAL
}

/// Dosya başına tek anlaşılan vekalet ücreti; dosya kasası (avans) ile ilişkilendirilmez.
model VekaletUcreti {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dosyaId      String   @unique @map("dosya_id")
  dosya        Dosya    @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  muvekkilId   String   @map("muvekkil_id")
  muvekkil     Muvekkil @relation(fields: [muvekkilId], references: [id], onDelete: Restrict)
  toplamTutar  Decimal  @map("toplam_tutar") @db.Decimal(14, 2)
  aciklama     String?
  createdById  String   @map("created_by_id")
  createdBy    User     @relation("VekaletUcretiCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById  String?  @map("updated_by_id")
  updatedBy    User?    @relation("VekaletUcretiUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  taksitler    VekaletTaksiti[]

  @@index([tenantId, muvekkilId])
  @@map("vekalet_ucreti")
}

model VekaletTaksiti {
  id              String                   @id @default(uuid())
  tenantId        String                   @map("tenant_id")
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dosyaId         String                   @map("dosya_id")
  dosya           Dosya                    @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  muvekkilId      String                   @map("muvekkil_id")
  muvekkil        Muvekkil                 @relation(fields: [muvekkilId], references: [id], onDelete: Restrict)
  vekaletUcretiId String                   @map("vekalet_ucreti_id")
  vekaletUcreti   VekaletUcreti            @relation(fields: [vekaletUcretiId], references: [id], onDelete: Cascade)
  taksitNo        Int                      @map("taksit_no")
  vadeTarihi      DateTime                 @map("vade_tarihi")
  tutar           Decimal                  @db.Decimal(14, 2)
  odemeDurumu     VekaletTaksitOdemeDurumu @default(ODENMEDI) @map("odeme_durumu")
  odemeTarihi     DateTime?                @map("odeme_tarihi")
  aciklama        String?
  makbuzNo        String?                  @map("makbuz_no")
  smmKesildiMi    Boolean                  @default(false) @map("smm_kesildi_mi")
  smmKesimTarihi  DateTime?                @map("smm_kesim_tarihi")
  smmNo           String?                  @map("smm_no")
  smmAciklama     String?                  @map("smm_aciklama")
  createdById     String                   @map("created_by_id")
  createdBy       User                     @relation("VekaletTaksitCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById     String?                  @map("updated_by_id")
  updatedBy       User?                    @relation("VekaletTaksitUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  odemeler        VekaletTaksitOdeme[]

  @@unique([vekaletUcretiId, taksitNo])
  @@index([tenantId, dosyaId])
  @@index([tenantId, dosyaId, odemeDurumu])
  @@map("vekalet_taksiti")
}

/// Vekalet taksitine bağlı kısmi veya tam tahsilat kaydı.
model VekaletTaksitOdeme {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  muvekkilId    String         @map("muvekkil_id")
  muvekkil      Muvekkil       @relation(fields: [muvekkilId], references: [id], onDelete: Restrict)
  dosyaId       String         @map("dosya_id")
  dosya         Dosya          @relation(fields: [dosyaId], references: [id], onDelete: Cascade)
  taksitId      String         @map("taksit_id")
  taksit        VekaletTaksiti @relation(fields: [taksitId], references: [id], onDelete: Cascade)
  odemeTarihi   DateTime       @map("odeme_tarihi")
  tutar         Decimal        @db.Decimal(14, 2)
  odemeYontemi  OdemeYontemi   @map("odeme_yontemi")
  aciklama      String?
  makbuzNo      String         @map("makbuz_no")
  smmKesildiMi  Boolean        @default(false) @map("smm_kesildi_mi")
  kasaHareketId String?        @unique @map("kasa_hareket_id")
  kasaHareket   KasaHareketi?  @relation(fields: [kasaHareketId], references: [id], onDelete: SetNull)
  ofisKasaHareketId String?    @unique @map("ofis_kasa_hareket_id")
  ofisKasaHareket   OfisKasaHareketi? @relation(fields: [ofisKasaHareketId], references: [id], onDelete: SetNull)
  createdById   String         @map("created_by_id")
  createdBy     User           @relation("VekaletTaksitOdemeCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  tahsilatiYapanUserId String? @map("tahsilati_yapan_user_id")
  tahsilatiYapanUser User?      @relation("VekaletOdemeTahsilatiYapan", fields: [tahsilatiYapanUserId], references: [id], onDelete: SetNull)
  tahsilatiYapanPersonelId String? @map("tahsilati_yapan_personel_id")
  tahsilatiYapanPersonel PrimPersonel? @relation("VekaletOdemeTahsilatiYapanPersonel", fields: [tahsilatiYapanPersonelId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@unique([tenantId, makbuzNo])
  @@index([tenantId, taksitId])
  @@index([tenantId, dosyaId])
  @@index([tenantId, smmKesildiMi])
  @@index([tenantId, tahsilatiYapanUserId, odemeTarihi])
  @@index([tenantId, tahsilatiYapanPersonelId, odemeTarihi])
  @@map("vekalet_taksit_odeme")
}

enum PrimKuralKapsam {
  TENANT_DEFAULT
  USER_SPECIFIC
}

enum PrimHesaplamaTipi {
  TOTAL_BRACKET
  PROGRESSIVE
}

enum PrimDonemTipi {
  MONTHLY
}

enum PrimDonemOdemeDurumu {
  HESAPLANDI
  ODENDI
}

/// Prim takibi için büro personeli (sistem kullanıcısı olmak zorunda değil).
model PrimPersonel {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adSoyad     String   @map("ad_soyad")
  telefon     String?
  eposta      String?
  unvan       String?
  aktifMi     Boolean  @default(true) @map("aktif_mi")
  not         String?
  bagliUserId String?  @unique @map("bagli_user_id")
  bagliUser   User?    @relation("PrimPersonelBagliUser", fields: [bagliUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  primKurallari              PrimKurali[]
  primDonemOdemeleri         PrimDonemOdemesi[]
  tahsilatlariYapanKasa      KasaHareketi[]        @relation("KasaTahsilatiYapanPersonel")
  tahsilatlariYapanVekalet   VekaletTaksitOdeme[]  @relation("VekaletOdemeTahsilatiYapanPersonel")
  tahsilatlariYapanOfisKasa  OfisKasaHareketi[]    @relation("OfisKasaTahsilatiYapanPersonel")
  tahsilatlariYapanIcraTahsilat IcraTahsilatOdeme[] @relation("IcraOdemeTahsilatiYapanPersonel")

  @@index([tenantId, aktifMi])
  @@index([tenantId, adSoyad])
  @@map("prim_personel")
}

enum IcraTahsilatAlacakTuru {
  KARSI_TARAF_VEKALET
  ICRA_VEKALET
}

enum IcraTahsilatAlacakDurum {
  ACIK
  KISMI_ODENDI
  ODENDI
  GECIKTI
  IPTAL
}

model IcraTahsilatAlacagi {
  id                       String                   @id @default(uuid())
  tenantId                 String                   @map("tenant_id")
  tenant                   Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alacakTuru               IcraTahsilatAlacakTuru   @map("alacak_turu")
  borcluAd                 String                   @map("borclu_ad")
  muvekkilId               String?                  @map("muvekkil_id")
  muvekkil                 Muvekkil?                @relation(fields: [muvekkilId], references: [id], onDelete: SetNull)
  dosyaId                  String?                  @map("dosya_id")
  dosya                    Dosya?                   @relation(fields: [dosyaId], references: [id], onDelete: SetNull)
  toplamTutar              Decimal                  @map("toplam_tutar") @db.Decimal(14, 2)
  pesinatTutar             Decimal                  @default(0) @map("pesinat_tutar") @db.Decimal(14, 2)
  taksitSayisi             Int                      @map("taksit_sayisi")
  ilkVadeTarihi            DateTime                 @map("ilk_vade_tarihi")
  varsayilanOdemeYontemi   OfisKasaOdemeYontemi     @map("varsayilan_odeme_yontemi")
  aciklama                 String?
  durum                    IcraTahsilatAlacakDurum  @default(ACIK)
  createdById              String                   @map("created_by_id")
  createdBy                User                     @relation("IcraAlacakCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById              String?                  @map("updated_by_id")
  updatedBy                User?                    @relation("IcraAlacakUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")
  taksitler                IcraTahsilatTaksit[]
  odemeler                 IcraTahsilatOdeme[]

  @@index([tenantId, durum])
  @@index([tenantId, createdAt])
  @@index([tenantId, muvekkilId])
  @@index([tenantId, dosyaId])
  @@map("icra_tahsilat_alacak")
}

model IcraTahsilatTaksit {
  id          String               @id @default(uuid())
  tenantId    String               @map("tenant_id")
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alacakId    String               @map("alacak_id")
  alacak      IcraTahsilatAlacagi  @relation(fields: [alacakId], references: [id], onDelete: Cascade)
  taksitNo    Int                  @map("taksit_no")
  tutar       Decimal              @db.Decimal(14, 2)
  vadeTarihi  DateTime             @map("vade_tarihi")
  aciklama    String?
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  odemeler    IcraTahsilatOdeme[]

  @@unique([alacakId, taksitNo])
  @@index([tenantId, alacakId])
  @@map("icra_tahsilat_taksit")
}

model IcraTahsilatOdeme {
  id                       String               @id @default(uuid())
  tenantId                 String               @map("tenant_id")
  tenant                   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alacakId                 String               @map("alacak_id")
  alacak                   IcraTahsilatAlacagi  @relation(fields: [alacakId], references: [id], onDelete: Cascade)
  taksitId                 String?              @map("taksit_id")
  taksit                   IcraTahsilatTaksit?  @relation(fields: [taksitId], references: [id], onDelete: SetNull)
  odemeTarihi              DateTime             @map("odeme_tarihi")
  tutar                    Decimal              @db.Decimal(14, 2)
  odemeYontemi             OfisKasaOdemeYontemi @map("odeme_yontemi")
  aciklama                 String?
  smmKesildiMi             Boolean              @default(false) @map("smm_kesildi_mi")
  pesinatMi                Boolean              @default(false) @map("pesinat_mi")
  ofisKasaHareketId        String?              @unique @map("ofis_kasa_hareket_id")
  ofisKasaHareket          OfisKasaHareketi?    @relation(fields: [ofisKasaHareketId], references: [id], onDelete: SetNull)
  tahsilatiYapanPersonelId String?              @map("tahsilati_yapan_personel_id")
  tahsilatiYapanPersonel   PrimPersonel?        @relation("IcraOdemeTahsilatiYapanPersonel", fields: [tahsilatiYapanPersonelId], references: [id], onDelete: SetNull)
  tahsilatiYapanUserId     String?              @map("tahsilati_yapan_user_id")
  tahsilatiYapanUser       User?                @relation("IcraOdemeTahsilatiYapan", fields: [tahsilatiYapanUserId], references: [id], onDelete: SetNull)
  createdById              String               @map("created_by_id")
  createdBy                User                 @relation("IcraOdemeCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt                DateTime             @default(now()) @map("created_at")
  updatedAt                DateTime             @updatedAt @map("updated_at")

  @@index([tenantId, alacakId])
  @@index([tenantId, taksitId])
  @@index([tenantId, tahsilatiYapanPersonelId, odemeTarihi])
  @@index([tenantId, smmKesildiMi])
  @@map("icra_tahsilat_odeme")
}

/// Personel tahsilat primi kuralı
model PrimKurali {
  id                 String              @id @default(uuid())
  tenantId           String              @map("tenant_id")
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ad                 String              @map("ad")
  aktifMi            Boolean             @default(true) @map("aktif_mi")
  kapsam             PrimKuralKapsam     @map("kapsam")
  userId             String?             @map("user_id")
  user               User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  primPersonelId     String?             @map("prim_personel_id")
  primPersonel       PrimPersonel?       @relation(fields: [primPersonelId], references: [id], onDelete: Cascade)
  hesaplamaTipi      PrimHesaplamaTipi   @map("hesaplama_tipi")
  donemTipi          PrimDonemTipi       @default(MONTHLY) @map("donem_tipi")
  dosyaTahsilatMi    Boolean             @default(true) @map("dosya_tahsilat_mi")
  vekaletTahsilatMi  Boolean             @default(true) @map("vekalet_tahsilat_mi")
  ofisKasaGelirMi    Boolean             @default(true) @map("ofis_kasa_gelir_mi")
  icraTahsilatMi     Boolean             @default(false) @map("icra_tahsilat_mi")
  kademeler          PrimKuralKademesi[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@index([tenantId, aktifMi])
  @@index([tenantId, kapsam, userId])
  @@index([tenantId, kapsam, primPersonelId])
  @@map("prim_kurali")
}

model PrimKuralKademesi {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kuralId   String     @map("kural_id")
  kural     PrimKurali @relation(fields: [kuralId], references: [id], onDelete: Cascade)
  minTutar  Decimal    @map("min_tutar") @db.Decimal(14, 2)
  maxTutar  Decimal?   @map("max_tutar") @db.Decimal(14, 2)
  oranYuzde Decimal    @map("oran_yuzde") @db.Decimal(6, 2)
  siraNo    Int        @map("sira_no")

  @@index([tenantId, kuralId])
  @@map("prim_kural_kademesi")
}

/// Aylık hesaplanan personel prim özeti
model PrimDonemOdemesi {
  id                  String               @id @default(uuid())
  tenantId            String               @map("tenant_id")
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId              String?              @map("user_id")
  user                User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  primPersonelId      String               @map("prim_personel_id")
  primPersonel        PrimPersonel         @relation(fields: [primPersonelId], references: [id], onDelete: Cascade)
  yil                 Int                  @map("yil")
  ay                  Int                  @map("ay")
  toplamTahsilat      Decimal              @map("toplam_tahsilat") @db.Decimal(14, 2)
  hesaplananPrim      Decimal              @map("hesaplanan_prim") @db.Decimal(14, 2)
  uygulananKuralId    String?              @map("uygulanan_kural_id")
  hesaplamaTipi       PrimHesaplamaTipi?   @map("hesaplama_tipi")
  hesaplamaDetay      Json?                @map("hesaplama_detay")
  durum               PrimDonemOdemeDurumu @default(HESAPLANDI)
  odendiTarihi        DateTime?            @map("odendi_tarihi")
  odendiIsaretleyenId String?              @map("odendi_isaretleyen_id")
  odendiIsaretleyen   User?                @relation("PrimDonemOdendiIsaretleyen", fields: [odendiIsaretleyenId], references: [id], onDelete: SetNull)
  not                 String?
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@unique([tenantId, primPersonelId, yil, ay])
  @@index([tenantId, yil, ay])
  @@index([tenantId, userId, yil, ay])
  @@map("prim_donem_odemesi")
}

/// Tek kullanımlık şifre sıfırlama jetonu (düz metin saklanmaz, yalnızca SHA-256 özeti).
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tokenHash])
  @@index([userId, createdAt])
  @@map("password_reset_token")
}

enum ImportBatchSourceType {
  DESKTOP_SQLITE
}

enum ImportBatchStatus {
  PREVIEWED
  COMMITTED
  FAILED
}

model ImportBatch {
  id                String                @id @default(uuid())
  tenantId          String                @map("tenant_id")
  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceType        ImportBatchSourceType @map("source_type")
  sourceFingerprint String                @map("source_fingerprint")
  fileName          String                @map("file_name")
  status            ImportBatchStatus
  rowCounts         Json?                 @map("row_counts")
  warnings          Json?
  errors            Json?
  committedAt       DateTime?             @map("committed_at")
  committedById     String?               @map("committed_by_id")
  committedBy       User?                 @relation(fields: [committedById], references: [id], onDelete: SetNull)
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  @@index([tenantId, sourceFingerprint])
  @@index([tenantId, status])
  @@map("import_batch")
}

/// Woontegra platform yöneticisi (büro kullanıcısı değildir).
enum SuperAdminRole {
  SUPER_ADMIN
  DESTEK
  FINANS
}

model SuperAdmin {
  id             String          @id @default(uuid())
  adSoyad        String          @map("ad_soyad")
  kullaniciAdi   String          @unique @map("kullanici_adi")
  eposta         String?         @unique @map("eposta")
  sifreHash      String          @map("sifre_hash")
  rol            SuperAdminRole
  aktifMi        Boolean         @default(true) @map("aktif_mi")
  sonGirisTarihi DateTime?       @map("son_giris_tarihi")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  adminAuditLogs AdminAuditLog[]

  @@map("super_admin")
}

/// Woontegra admin işlem kaydı (kiracı audit_log’dan ayrı).
model AdminAuditLog {
  id         String      @id @default(uuid())
  adminId    String?     @map("admin_id")
  admin      SuperAdmin? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action     String
  entityType String?     @map("entity_type")
  entityId   String?     @map("entity_id")
  oldValue   Json?       @map("old_value")
  newValue   Json?       @map("new_value")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([adminId, createdAt])
  @@index([entityType, entityId])
  @@map("admin_audit_log")
}
